# ============================================================
# SecurePay — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securepay
DB_USER=securepay_user
DB_PASSWORD=securepay_pass
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_64_CHARS_MINIMUM
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_STRONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ── AES-256 Encryption (for API keys at rest) ────────────────
# MUST be a 64-character hex string (32 bytes = 256 bits).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_0123456789abcdef0123456789abcdef01234567

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

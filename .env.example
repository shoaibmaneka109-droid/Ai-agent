# ============================================================
#  SecurePay — Environment Variables
#  Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securepay
DB_USER=securepay_user
DB_PASSWORD=your_strong_db_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ─────────────────────────────────────────────────────
# Generate secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AES-256-GCM Encryption ──────────────────────────────────
# CRITICAL: 64-character hex string (32 bytes)
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Frontend ────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3001/api/v1

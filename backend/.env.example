# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securepay
DB_USER=securepay_user
DB_PASSWORD=your_db_password_here
DB_SSL=false

# JWT
JWT_SECRET=your_jwt_secret_minimum_64_chars_here_replace_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_minimum_64_chars_here_replace_in_production
JWT_REFRESH_EXPIRES_IN=7d

# AES-256 Encryption (32-byte hex key = 64 hex characters)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_64_chars_replace_in_production
ENCRYPTION_IV_LENGTH=16

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

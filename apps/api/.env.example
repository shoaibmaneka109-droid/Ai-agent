PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/securepay
# 32-byte key, base64-encoded (openssl rand -base64 32)
SECUREPAY_MASTER_KEY_BASE64=
# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN_DAYS=7
# When API is behind a reverse proxy, set to 1 so client IP comes from X-Forwarded-For (VPS IP checks)
TRUST_PROXY=0
# Comma-separated origins for Socket.IO (agency dashboard); use * only in dev if needed
SOCKET_CORS_ORIGIN=http://localhost:5173
# Fund recall: "simulated" (default, audit + DB row) or "live" (Stripe API checks; extend fundRecall.ts for full transfer)
STRIPE_ISSUING_RECALL_MODE=simulated

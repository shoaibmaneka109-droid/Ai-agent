{
  "name": "securepay",
  "version": "0.1.0",
  "private": true,
  "description": "SecurePay multi-tenant SaaS platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:api": "npm run dev -w @securepay/api",
    "dev:web": "npm run dev -w @securepay/web"
  },
  "engines": {
    "node": ">=20"
  }
}

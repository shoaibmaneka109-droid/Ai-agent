{
  "name": "securepay",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "start:api": "npm run start -w apps/api",
    "build:web": "npm run build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

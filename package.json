{
  "name": "securepay",
  "private": true,
  "version": "0.1.0",
  "description": "SecurePay — multi-tenant SaaS (Solo & Agency)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @securepay/api",
    "dev:web": "npm run dev -w @securepay/web",
    "build": "npm run build -w @securepay/shared && npm run build -w @securepay/api && npm run build -w @securepay/web"
  },
  "engines": {
    "node": ">=20"
  }
}
